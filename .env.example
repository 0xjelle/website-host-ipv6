# ── Hosting configuration ──────────────────────────────────────────
# Copy to .env (or export in your environment) and adjust.

# Port for the dashboard + API
ADMIN_PORT=3000

# Port the public reverse proxy listens on (put 80 in production,
# or keep 8080 and front it with Caddy/nginx for TLS)
PROXY_PORT=8080

# Secret used to sign session tokens. CHANGE THIS.
JWT_SECRET=change-me-to-a-long-random-string

# Where site checkouts, the database and generated configs live
DATA_DIR=./data

# Public hostname of this server (used in webhook URLs and WireGuard
# client configs), e.g. host.example.com or an IP
PUBLIC_HOST=localhost

# First internal port handed out to Node.js apps
APP_PORT_BASE=20100

# Public HTTPS port for the edge proxy (Let's Encrypt certs via DNS-01)
PROXY_TLS_PORT=443

# Set to 1 to use Let's Encrypt STAGING (untrusted certs, for testing)
SSL_STAGING=0

# Cloudflare (DDoS protection). When this platform is served behind Cloudflare
# (its domain + free per-site subdomains are proxied / "orange-clouded"), the
# edge proxy recovers each visitor's real IP from the CF-Connecting-IP header —
# but only when the connection actually comes from a Cloudflare IP, so it can't
# be spoofed. This is on by default and configurable in the dashboard
# (Administration → Cloudflare). Set to 0 to force it off for this deployment
# (e.g. if you front the proxy with something other than Cloudflare).
TRUST_CLOUDFLARE=1

# Per-site container isolation. When 1 (and Docker is installed), every Node
# app runs in its own Docker container (node:22) with CPU/memory limits and a
# private filesystem/network — strong isolation between tenants. Deps are
# installed and the app is built inside the container. When 0 (default), apps
# run as dedicated unprivileged users instead. Static sites are always served
# directly by the edge proxy (no code runs, so no container needed).
USE_CONTAINERS=0
# Per-container resource caps (only used when USE_CONTAINERS=1).
SITE_MEM=512m
SITE_CPUS=1
