# ── Hosting configuration ──────────────────────────────────────────
# Copy to .env (or export in your environment) and adjust.

# Port for the dashboard + API
ADMIN_PORT=3000

# Port the public reverse proxy listens on (put 80 in production,
# or keep 8080 and front it with Caddy/nginx for TLS)
PROXY_PORT=8080

# Secret used to sign session tokens. CHANGE THIS.
JWT_SECRET=change-me-to-a-long-random-string

# Where site checkouts, the database and generated configs live
DATA_DIR=./data

# Public hostname of this server (used in webhook URLs and WireGuard
# client configs), e.g. host.example.com or an IP
PUBLIC_HOST=localhost

# First internal port handed out to Node.js apps
APP_PORT_BASE=20100

# Public HTTPS port for the edge proxy (Let's Encrypt certs via DNS-01)
PROXY_TLS_PORT=443

# Set to 1 to use Let's Encrypt STAGING (untrusted certs, for testing)
SSL_STAGING=0

# Cloudflare (DDoS protection). When this platform is served behind Cloudflare
# (its domain + free per-site subdomains are proxied / "orange-clouded"), the
# edge proxy recovers each visitor's real IP from the CF-Connecting-IP header -
# but only when the connection actually comes from a Cloudflare IP, so it can't
# be spoofed. This is on by default and configurable in the dashboard
# (Administration → Cloudflare). Set to 0 to force it off for this deployment
# (e.g. if you front the proxy with something other than Cloudflare).
TRUST_CLOUDFLARE=1

# Per-site container isolation. When 1 (and Docker is installed), every Node
# app runs in its own Docker container (node:22) with CPU/memory limits and a
# private filesystem/network - strong isolation between tenants. Deps are
# installed and the app is built inside the container. When 0 (default), apps
# run as dedicated unprivileged users instead. Static sites are always served
# directly by the edge proxy (no code runs, so no container needed).
USE_CONTAINERS=0
# Per-container resource caps (only used when USE_CONTAINERS=1).
SITE_MEM=512m
SITE_CPUS=1

# Email (Resend). Enables password-reset links and notifications (deploy failed,
# certificate expiring, site down). Get an API key at resend.com and verify your
# sending domain. Without a key, email features stay dormant (the platform still
# works). MAIL_FROM must be an address on a domain you've verified in Resend.
RESEND_API_KEY=
MAIL_FROM=Hosting <no-reply@jelle.website>

# Billing via Stripe. Leave blank to run free with no billing.
#
# Stripe Tax is enabled at checkout so the correct EU/Belgian VAT is calculated
# and collected - but NOTE Stripe is not a merchant of record: you are the
# seller of record and must register (e.g. VAT OSS) and remit that VAT yourself.
#
# Setup: create a recurring Price with "usage type: licensed" (per-unit) in the
# Stripe dashboard, then add a webhook endpoint pointing at
# /api/billing/webhook subscribed to:
#   checkout.session.completed, customer.subscription.created,
#   customer.subscription.updated, customer.subscription.deleted,
#   invoice.payment_failed
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price id of the per-site subscription. Billing is PAY PER SITE: the
# subscription quantity is kept equal to the account's number of sites.
STRIPE_PRICE_PERSITE=
# Label shown in the Billing UI (display only - the real amount comes from the
# Stripe price). There is no free tier: an account must subscribe to host a site.
BILLING_PRICE_LABEL=€20 / site / month
# Day of the month every subscription is billed on (1-28, default 1). New
# subscribers pay pro rata for the days until this date, then the full amount on
# it every month - so all invoices land on the same day. Cancelling keeps the
# subscription (and the customer's sites) running until the paid period ends.
BILLING_ANCHOR_DAY=1

# Cloudflare Turnstile (CAPTCHA on login + signup). Create a widget at
# dash.cloudflare.com → Turnstile. Leave blank to disable (auth then works with
# no captcha). The site key is public; the secret key is used server-side.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

